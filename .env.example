# Supabase (required for the app to function)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase server-side (for scripts/admin only, not needed for frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI / API keys (for agent service and admin features)
OPENAI_API_KEY=your-openai-key
OPEN_ROUTER_API_KEY=your-openrouter-key
ELEVENLABS_API_KEY=your-elevenlabs-key
RUNWAY_API_KEY=your-runway-key

# Google Cloud (for specific integrations)
GOOGLE_CLOUD_PROJECT=your-project
GOOGLE_CLOUD_REGION=your-region
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GEMINI_API_KEY=your-gemini-api-key

# Unipile (for inbox/messaging features)
UNIPILE_API_KEY=your-unipile-key
UNIPILE_DSN=your-unipile-dsn
UNIPILE_SAFE_MODE=true

# Feature flags
ENABLE_BLOG_AGENT=false
ENABLE_CHAT_ORCHESTRATOR=false

# Environment
ENVIRONMENT=development
PROJECT_NAME=lifetrek
